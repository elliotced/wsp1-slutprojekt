<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CloudWave - <%=@current_page%></title>
  <link rel="stylesheet" href="/style.css?<%=Time.now.to_i%>">
</head>

<body>
  <div class="app">

    <aside class="sidebar">
      <div class="sidebar-header">
        <h1 class="logo">CloudWave</h1>
      </div>

      <nav class="nav">
        <a href="/" class="nav-item">Home</a>
        <a href="/users" class="nav-item">User</a>
      </nav>
    </aside>

    <main class="content">
      <header class="content-header">
        <h2><%= @current_page %></h2>
      </header>

      <section class="content-body">
        <%= yield %>
      </section>
    </main>

  </div>
</body>
</html>